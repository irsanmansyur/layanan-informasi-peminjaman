# ============================================================
# Copy this file to .env.production and edit the values marked
# with CHANGE_ME before running `docker compose up -d`.
# ============================================================

APP_NAME=KIOS95
APP_ENV=production
APP_KEY=                              # CHANGE_ME  — generate with: docker compose run --rm app php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://your-domain.com       # CHANGE_ME  — public URL used for asset links & Storage::url()

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---- Logging ----
LOG_CHANNEL=stack
LOG_STACK=stderr          # write to container stderr so `docker logs` works
LOG_LEVEL=warning

# ---- Trusted proxies (IMPORTANT when behind Traefik/Nginx/Cloudflare) ----
# Use '*' to trust all — safe because Docker network is private.
TRUSTED_PROXIES=*

# ---- Database (SQLite on persistent volume) ----
DB_CONNECTION=sqlite
DB_DATABASE=/app/storage/app/database/database.sqlite

# ---- Sessions / Queue / Cache — all on DB (no Redis) ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log

# ---- Filesystem ----
FILESYSTEM_DISK=public

# ---- Mail (adjust to your SMTP / SES / Mailgun) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Vite ----
VITE_APP_NAME="${APP_NAME}"

# ---- Container behavior ----
RUN_MIGRATIONS=true        # set to false to opt out of auto-migrate on boot
