# FrankenPHP Caddyfile — runs BEHIND an external reverse proxy
# (Traefik / Nginx / Cloudflare tunnel). TLS is terminated upstream.
#
# NOTE: `php_server` is the canonical Laravel/Symfony shortcut. It already
# bundles: rewrite to index.php, try_files, and file_server for static assets.
# Do NOT add a standalone `file_server` or a `try_files` sub-block — that
# breaks the default and causes `/` to return 404.

{
    # Disable Caddy's automatic TLS — upstream proxy handles it
    auto_https off

    # Trust forwarding headers from private networks (docker/LAN)
    servers {
        trusted_proxies static private_ranges
    }

    # Access logs to stdout so `docker logs` captures them
    log {
        output stdout
        format json
        level INFO
    }
}

# Matches SERVER_NAME=:8000 env var
:8000 {
    root * /app/public

    encode zstd gzip

    # Long cache for hashed Vite build artifacts (immutable filenames)
    @vite path /build/*
    header @vite Cache-Control "public, max-age=31536000, immutable"

    # PHP handler — single directive that handles everything Laravel needs:
    #   - serves static files under /app/public if they exist
    #   - rewrites missing paths to /index.php
    #   - executes PHP via the embedded FrankenPHP runtime
    php_server

    # Log requests (stdout)
    log {
        output stdout
        format json
    }
}
